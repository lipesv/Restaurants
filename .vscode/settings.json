{
    "editor.semanticTokenColorCustomizations": {
        "rules": {
            "interface": {
                "foreground": "#b8ce82"
            },
            "namespace": "#cccccc",
            "enum": "#b8ce82",
            "struct": {
                "foreground": "#86C691"
            }
        }
    },
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": "keyword.control.sql, keyword.control.client.sql, keyword.control.set.sql",
                "settings": {
                    "foreground": "#569CD6"
                }
            },
            {
                "scope": "storage.type.string.sql, storage.type.numeric.sql, storage.type.datetime.sql",
                "settings": {
                    "foreground": "#9CDCFE"
                }
            },
            {
                "scope": "support.function.string.sql, support.function.numeric.sql, support.function.datetime.sql, support.function.advanced.sql",
                "settings": {
                    "foreground": "#DCDCAA"
                }
            },
            {
                "scope": "string.quoted.single.sql, string.quoted.double.sql, string.quoted.multi-line.sql, string.quoted.backtick.sql",
                "settings": {
                    "foreground": "#CE9178"
                }
            },
            {
                "scope": "constant.numeric.sql",
                "settings": {
                    "foreground": "#B5CEA8"
                }
            },
            {
                "scope": "comment.line.double-dash.sql, comment.block.sql, comment.line.hash.sql, comment.conditional.sql",
                "settings": {
                    "foreground": "#6A9955"
                }
            },
            {
                "scope": "keyword.operator.sql, keyword.operator.advanced.sql",
                "settings": {
                    "foreground": "#D4D4D4"
                }
            },
            {
                "scope": "entity.name.function.sql, entity.name.table.sql, entity.name.column.sql, variable.global.sql, variable.session.sql, variable.other.sql, variable.user-defined.sql",
                "settings": {
                    "foreground": "#D4D4D4"
                }
            },
            {
                "scope": [
                    "punctuation.definition.bracket"
                ],
                "settings": {
                    "foreground": "#D4D4D4"
                }
            },
            {
                "scope": "entity.name.type.interface.cs",
                "settings": {
                    "foreground": "#b8ce82"
                }
            },
            {
                "scope": "entity.name.type.enum.cs",
                "settings": {
                    "foreground": "#b8ce82"
                }
            },
            {
                "scope": "entity.name.type.struct.cs",
                "settings": {
                    "foreground": "#86C691"
                }
            },
            {
                "scope": "variable.other.enummember.cs",
                "settings": {
                    "foreground": "#4FC1FF"
                }
            }
        ]
    },
    "appService.defaultWebAppToDeploy": "/subscriptions/917ef8fb-4fe2-42b3-b8a9-21bc769395ff/resourceGroups/rg-restaurants-dev/providers/Microsoft.Web/sites/restaurants-api-dev",
    "appService.deploySubpath": "artifacts/azure/Restaurants.API",
    "csharp-dev-tools.entityFramework.migrationPreferences": {
        "Restaurants.sln": {
            "startupProject": "src/Restaurants.API/Restaurants.API.csproj",
            "migrationsProject": "src/Restaurants.Infrastructure/Restaurants.Infrastructure.csproj",
            "dbContextClass": "RestaurantsDbContext",
            "migrationsFolder": "Migrations",
            "targetMigration": "RestaurantLogoUrlAdded"
        }
    }
}