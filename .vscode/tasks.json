{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/Restaurants.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            // "dependsOn": [
            //     "local-environment-start"
            // ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/Restaurants.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/Restaurants.sln"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "type": "docker-build",
            "label": "docker-build: debug",
            "dependsOn": [
                "build"
            ],
            "dockerBuild": {
                "tag": "restaurants:dev",
                "target": "base",
                "dockerfile": "${workspaceFolder}/Restaurants.API/Dockerfile",
                "context": "${workspaceFolder}",
                "pull": true
            },
            "netCore": {
                "appProject": "${workspaceFolder}/Restaurants.API/Restaurants.API.csproj"
            }
        },
        {
            "type": "docker-build",
            "label": "docker-build: release",
            "dependsOn": [
                "build"
            ],
            "dockerBuild": {
                "tag": "restaurants:latest",
                "dockerfile": "${workspaceFolder}/Restaurants.API/Dockerfile",
                "context": "${workspaceFolder}",
                "platform": {
                    "os": "linux",
                    "architecture": "amd64"
                },
                "pull": true
            },
            "netCore": {
                "appProject": "${workspaceFolder}/Restaurants.API/Restaurants.API.csproj"
            }
        },
        {
            "type": "docker-run",
            "label": "docker-run: debug",
            "dependsOn": [
                "docker-build: debug"
            ],
            "dockerRun": {},
            "netCore": {
                "appProject": "${workspaceFolder}/Restaurants.API/Restaurants.API.csproj",
                "enableDebugging": true
            }
        },
        {
            "type": "docker-run",
            "label": "docker-run: release",
            "dependsOn": [
                "docker-build: release"
            ],
            "dockerRun": {},
            "netCore": {
                "appProject": "${workspaceFolder}/Restaurants.API/Restaurants.API.csproj"
            }
        },
        {
            "label": "docker-compose: up [database]",
            "type": "shell",
            "command": "docker compose up -d database",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "local-environment-start",
            "type": "shell",
            "command": "./scripts/environment/dev.sh",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "local-environment-cleanup",
            "type": "shell",
            "command": "docker compose down -v",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "clean-publish-folder",
            "type": "shell",
            "command": "rm -rf \"${workspaceFolder}/artifacts/azure/Restaurants.API\" && mkdir -p \"${workspaceFolder}/artifacts/azure/Restaurants.API\"",
            "problemMatcher": []
        },
        {
            "label": "publish-api-azure",
            "type": "process",
            "command": "dotnet",
            "args": [
                "publish",
                "${workspaceFolder}/src/Restaurants.API/Restaurants.API.csproj",
                "-c",
                "Release",
                "-o",
                "${workspaceFolder}/artifacts/azure/Restaurants.API"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "prepare-azure-deploy",
            "dependsOn": [
                "clean-publish-folder",
                "publish-api-azure"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}